{
    "name": "iamtinhr/laravel-h5p",
    "description": "H5P integration for Laravel without any additional dependencies.",
    "type": "package",
    "require": {
        "php": ">=8.1",
        "bensampo/laravel-enum": "^6.0",
        "laravel/framework": "^10.0",
        "h5p/h5p-core": "^1.24|dev-master",
        "h5p/h5p-editor": "^1.24|dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0",
        "laravel/legacy-factories": "^1.0.4",
        "guzzlehttp/guzzle": "^7"
    },
    "autoload": {
        "psr-4": {
            "Iamtinhr\\LaravelH5P\\": "src",
            "Iamtinhr\\LaravelH5P\\Database\\Factories\\": "database/factories",
            "Iamtinhr\\LaravelH5P\\Database\\Seeders\\": "database/seeders"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Iamtinhr\\LaravelH5P\\Tests\\": "tests"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Nguyen Tinh",
            "email": "iamtinhr.contact@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Iamtinhr\\LaravelH5P\\HeadlessH5PServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
